---
export interface Props {
  tag: string;
  title: string;
  description: string;
  badges?: string[];
  linkLabel?: string;
  linkHref?: string;
  secondaryLinkLabel?: string;
  secondaryLinkHref?: string;
  note?: string;
  muted?: boolean;
}

const { tag, title, description, badges = [], linkLabel, linkHref, secondaryLinkLabel, secondaryLinkHref, note, muted = false } = Astro.props;
---

<article
  class="work-card rounded-sm p-8 transition-transform duration-200"
  style={`border: 1px solid var(--border); background-color: var(--card-bg); opacity: ${muted ? '0.7' : '1'};`}
>
  <p
    class="mb-3 text-xs font-medium uppercase tracking-widest"
    style="color: var(--muted); letter-spacing: 0.12em;"
  >
    {tag}
  </p>

  <h3
    class="font-serif mb-3 text-2xl font-medium tracking-tight"
    style="color: var(--text);"
  >
    {title}
  </h3>

  <p class="mb-5 text-sm leading-relaxed" style="color: var(--muted);">
    {description}
  </p>

  {
    badges.length > 0 && (
      <div class="mb-5 flex flex-wrap gap-2">
        {badges.map((badge) => (
          <span
            class="rounded-sm px-2 py-0.5 text-xs"
            style="font-family: var(--font-mono); color: var(--muted); border: 1px solid var(--border);"
          >
            {badge}
          </span>
        ))}
      </div>
    )
  }

  {
    linkLabel && linkHref ? (
      <div class="flex flex-wrap gap-4">
        <a
          href={linkHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm font-medium"
          style="color: var(--accent); text-decoration: none;"
        >
          {linkLabel}&nbsp;→
        </a>
        {secondaryLinkLabel && secondaryLinkHref && (
          <a
            href={secondaryLinkHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm font-medium"
            style="color: var(--accent); text-decoration: none;"
          >
            {secondaryLinkLabel}&nbsp;→
          </a>
        )}
      </div>
    ) : note ? (
      <p class="text-sm italic" style="color: var(--muted);">
        {note}
      </p>
    ) : (
      <p class="text-sm italic" style="color: var(--muted);">
        Drafting
      </p>
    )
  }
</article>

<style>
  .work-card:hover {
    transform: translateY(-2px);
  }
</style>
