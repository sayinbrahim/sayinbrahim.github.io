---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import WorkCard from '../components/WorkCard.astro';
import Writing from '../components/Writing.astro';
import Stack from '../components/Stack.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout>
  <Hero />

  <About />

  <Experience />

  <!-- Selected Work -->
  <section class="mx-auto max-w-5xl px-6 py-24 md:py-32" id="work">
    <h2
      class="font-serif mb-10 text-4xl font-medium tracking-tight md:text-5xl"
      style="color: var(--text);"
    >
      Selected Work
    </h2>

    <div class="flex flex-col gap-5">
      <WorkCard
        tag="Open Source · MCP · Roslyn"
        title="dotnet-context-mcp"
        description="Solution-aware Model Context Protocol server for .NET, built on Roslyn Workspace API. Gives Claude Code structured access to DbContexts, entities, migrations, and entity relationship graphs. Bridge MCP pattern: TypeScript protocol layer + .NET 8 CLI analysis layer."
        badges={['.NET 8', 'TypeScript', 'Roslyn', 'MCP', 'npm']}
        linkLabel="View on GitHub"
        linkHref="https://github.com/sayinbrahim/dotnet-context-mcp"
        secondaryLinkLabel="npm package"
        secondaryLinkHref="https://www.npmjs.com/package/dotnet-context-mcp"
      />

      <WorkCard
        tag="Open Source · Roslyn Analyzer · CLI"
        title="ef-migration-safety"
        description="Static analysis CLI for Entity Framework Core migrations. Detects risky operations before deployment: data loss patterns, SQL injection risks, missing defaults, cascading drops. 6 analyzers covering common EF Core migration hazards."
        badges={['.NET 8', 'Roslyn', 'CLI', 'NuGet']}
        linkLabel="View on GitHub"
        linkHref="https://github.com/sayinbrahim/ef-migration-safety"
        secondaryLinkLabel="NuGet package"
        secondaryLinkHref="https://www.nuget.org/packages/EfMigrationSafety.Cli"
      />

      <WorkCard
        tag="Contribution · Documentation"
        title="Microsoft EF Core Documentation"
        description="Contributor to the official Entity Framework Core documentation. Improvements to the migrations guides covering advanced scenarios: transactional application, multi-provider workflows, and managing migrations across teams."
        badges={['EF Core', 'Documentation', 'Open Source']}
        linkLabel="Merged PR #5390"
        linkHref="https://github.com/dotnet/EntityFramework.Docs/pull/5390"
        secondaryLinkLabel="PR #5402 (in review)"
        secondaryLinkHref="https://github.com/dotnet/EntityFramework.Docs/pull/5402"
      />

      <WorkCard
        tag="Case Study · Enterprise Migration"
        title="Oracle to PostgreSQL Migration"
        description="Enterprise-scale database migration for a mission-critical energy sector system. Schema translation, stored procedure conversion, data pipeline migration, and zero-downtime cutover strategy across multiple environments."
        badges={['Oracle', 'PostgreSQL', '.NET', 'Enterprise']}
        note="Case study available on request"
      />

      <WorkCard
        tag="Open Source · Playbooks"
        title="claude-code-for-dotnet"
        description="Skills, playbooks, and workflow templates for using Claude Code on .NET projects. Living document based on real-world usage patterns."
        badges={['Claude Code', '.NET', 'Playbooks']}
        linkLabel="View on GitHub"
        linkHref="https://github.com/sayinbrahim/claude-code-for-dotnet"
        muted={true}
      />
    </div>
  </section>

  <Writing />

  <Stack />

  <Contact />
</BaseLayout>
