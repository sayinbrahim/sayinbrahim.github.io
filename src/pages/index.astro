---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import WorkCard from '../components/WorkCard.astro';
import Writing from '../components/Writing.astro';
import Stack from '../components/Stack.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout>
  <Hero />

  <About />

  <Experience />

  <!-- Selected Work -->
  <section class="mx-auto max-w-5xl px-6 py-24 md:py-32" id="work">
    <h2
      class="font-serif mb-10 text-4xl font-medium tracking-tight md:text-5xl"
      style="color: var(--text);"
    >
      Selected Work
    </h2>

    <div class="flex flex-col gap-5">
      <WorkCard
        tag="Open Source · Released on NuGet"
        title="ef-migration-safety"
        description="A .NET CLI tool that statically analyzes EF Core migration files and flags destructive operations, missing defaults, empty Down() methods, and unsafe rename operations before they reach production. Built with Roslyn; distributed as a global dotnet tool on NuGet."
        badges={['.NET 8', 'Roslyn', 'CLI', 'Static Analysis', 'NuGet']}
        linkLabel="View on GitHub"
        linkHref="https://github.com/sayinbrahim/ef-migration-safety"
        secondaryLinkLabel="Install via NuGet"
        secondaryLinkHref="https://www.nuget.org/packages/EfMigrationSafety.Cli"
      />

      <WorkCard
        tag="Open Source · Active"
        title="claude-code-for-dotnet"
        description="A production-grade collection of skills, playbooks, and CLAUDE.md templates for shipping enterprise .NET code with Claude Code — designed around the patterns that survive audit and compliance review in regulated environments. Covers structured logging architecture, EF Core migration safety reviews, and legacy .NET modernization playbooks. Maintained as a living document."
        badges={['Claude Code', '.NET 8', 'EF Core', 'Serilog', 'xUnit']}
        linkLabel="View on GitHub"
        linkHref="https://github.com/sayinbrahim/claude-code-for-dotnet"
      />

      <WorkCard
        tag="Side Project · AI + Astrology"
        title="ZephryAstro"
        description="A full-stack AI-augmented astrology platform combining classical natal chart computation (SwissEphNet) with structured content generation pipelines. Architected the .NET 8 backend, React frontend, and Python content automation layers — shipping daily Turkish-language content across Instagram and X, with a long-term aim of a paid natal and solar return reporting platform."
        badges={['.NET 8', 'React', 'SwissEphNet', 'Python', 'Pillow']}
        linkLabel="Follow on Instagram"
        linkHref="https://instagram.com/zephryastro"
      />

      <WorkCard
        tag="Case Study · Energy Sector"
        title="Oracle to PostgreSQL Migration"
        description="Architected and executed the migration of a multi-million-row enterprise dataset from a legacy Oracle deployment to PostgreSQL — rewriting Oracle-specific PL/SQL into PostgreSQL equivalents, restructuring schema patterns, and validating data integrity across the cutover window. Preserved query semantics and reporting pipeline performance while reducing licensing costs."
        badges={['Oracle', 'PostgreSQL', 'PL/SQL', 'T-SQL', '.NET 8', 'EF Core']}
        note="Case study available on request"
      />

    </div>
  </section>

  <Writing />

  <Stack />

  <Contact />
</BaseLayout>
